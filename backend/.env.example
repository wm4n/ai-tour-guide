# Gemini API
GEMINI_API_KEY=your-key-here

# Google Places API
GOOGLE_PLACES_API_KEY=

# Backend service
HOST=0.0.0.0
PORT=8000

# Cache directories (defaults to /tmp/tour_guide_cache, /tmp/tour_guide_narration_cache)
POI_CACHE_DIR=
NARRATION_CACHE_DIR=

# API Key for X-Api-Key middleware (leave empty to disable auth in development)
API_KEY=

# Logging
LOG_LEVEL=INFO     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text    # text | json (use json for Cloud Run)
