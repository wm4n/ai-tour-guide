# GCP configuration for setup-gcp.sh and deploy-backend.sh
# Copy to scripts/.env and fill in your values (scripts/.env is gitignored)

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-east1
ARTIFACT_REPO=tour-guide-backend
CLOUD_RUN_SERVICE=tour-guide-backend
SECRET_NAME=api-key
# MIN_INSTANCES=1  # Uncomment to keep one instance warm (prevents cold starts)
